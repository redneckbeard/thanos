{
  "json": {
    "go_imports": ["github.com/redneckbeard/thanos/shims"],
    "modules": {
      "JSON": {
        "methods": {
          "generate": {
            "call": ["shims.JSONGenerate"],
            "returns": "string"
          },
          "pretty_generate": {
            "call": ["shims.JSONPrettyGenerate"],
            "returns": "string"
          },
          "dump": {
            "call": ["shims.JSONGenerate"],
            "returns": "string"
          },
          "parse": {
            "call": ["shims.JSONParse"],
            "returns": "{string: string}",
            "returns_go": "map[string]string"
          }
        }
      }
    }
  }
}
